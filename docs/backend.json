
{
  "entities": {
    "School": {
      "title": "School",
      "type": "object",
      "description": "Represents a school, which is a tenant in the NutriPass system.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "subdomain": { "type": "string", "description": "Unique subdomain for the school (e.g., 'cumbres')" },
        "address": { "type": "string" },
        "contactEmail": { "type": "string", "format": "email" },
        "staffDiscountActive": { "type": "boolean", "default": false },
        "staffDiscountPercentage": { "type": "number" },
        "isActive": { "type": "boolean" },
        "logoUrl": { "type": "string", "description": "URL to the school logo." },
        "primaryColor": { "type": "string", "description": "Primary brand color in Hex format.", "default": "#7CB9E8" },
        "secondaryColor": { "type": "string", "description": "Secondary brand color in Hex format.", "default": "#F4C430" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "contactEmail", "isActive", "createdAt", "updatedAt"]
    },
    "SchoolMember": {
      "title": "SchoolMember",
      "type": "object",
      "description": "Unified entity for students and staff within a school.",
      "properties": {
        "id": { "type": "string" },
        "schoolId": { "type": "string" },
        "profileId": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "identifier": { "type": "string" },
        "userType": { "type": "string", "enum": ["student", "staff"] },
        "nfcTagUid": { "type": "string" },
        "grade": { "type": "string" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "schoolId", "firstName", "lastName", "userType", "isActive"]
    },
    "Product": {
      "title": "Product",
      "type": "object",
      "description": "Cafeteria items available for purchase.",
      "properties": {
        "id": { "type": "string" },
        "schoolId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string", "enum": ["snack", "comedor", "bebida"] },
        "barcode": { "type": "string", "description": "EAN/UPC barcode for quick inventory management." },
        "stockQuantity": { "type": "integer", "default": 0, "description": "Inventory level for snacks and drinks." },
        "isAvailable": { "type": "boolean" },
        "image": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "schoolId", "name", "price", "category", "isAvailable"]
    },
    "DailyMenu": {
      "title": "DailyMenu",
      "type": "object",
      "description": "A specific product offered on a particular date.",
      "properties": {
        "id": { "type": "string" },
        "schoolId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "price": { "type": "number" },
        "availableQuantity": { "type": "number" }
      },
      "required": ["id", "schoolId", "date", "productId"]
    },
    "PreOrder": {
      "title": "PreOrder",
      "type": "object",
      "description": "A pre-paid meal reservation.",
      "properties": {
        "id": { "type": "string" },
        "schoolId": { "type": "string" },
        "memberId": { "type": "string" },
        "menuId": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["paid", "consumed", "cancelled"] },
        "totalPrice": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "schoolId", "memberId", "menuId", "status", "totalPrice"]
    }
  },
  "firestore": {
    "structure": [
      {
        "path": "/schools/{schoolId}",
        "definition": { "entityName": "School", "schema": { "$ref": "#/backend/entities/School" } }
      },
      {
        "path": "/schools/{schoolId}/members/{memberId}",
        "definition": { "entityName": "SchoolMember", "schema": { "$ref": "#/backend/entities/SchoolMember" } }
      },
      {
        "path": "/schools/{schoolId}/products/{productId}",
        "definition": { "entityName": "Product", "schema": { "$ref": "#/backend/entities/Product" } }
      },
      {
        "path": "/schools/{schoolId}/menus/{menuId}",
        "definition": { "entityName": "DailyMenu", "schema": { "$ref": "#/backend/entities/DailyMenu" } }
      },
      {
        "path": "/schools/{schoolId}/preOrders/{orderId}",
        "definition": { "entityName": "PreOrder", "schema": { "$ref": "#/backend/entities/PreOrder" } }
      }
    ]
  }
}
