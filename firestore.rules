
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      // Safely attempt to get user data if signed in
      return isSignedIn() ? get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data : null;
    }

    function hasRole(role) {
      let data = getUserData();
      return data != null && data.role == role;
    }

    function isSuperAdmin() {
      return hasRole('super_admin');
    }

    function isSchoolAdmin(schoolId) {
      let data = getUserData();
      return data != null && data.role == 'school_admin' && data.schoolId == schoolId;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /profiles/{profileId} {
      allow get: if isSignedIn() && (isOwner(profileId) || isSuperAdmin());
      allow list: if isSuperAdmin();
      allow create: if isOwner(profileId);
      allow update: if (isOwner(profileId) || isSuperAdmin()) && resource != null;
      allow delete: if isSuperAdmin() && resource != null;
    }

    match /schools/{schoolId} {
      // Allow public read for schools in prototype
      allow get, list: if true;
      allow create: if isSuperAdmin();
      allow update: if (isSuperAdmin() || isSchoolAdmin(schoolId)) && resource != null;
      allow delete: if isSuperAdmin() && resource != null;
    }

    match /schools/{schoolId}/members/{memberId} {
      // Allow read if user belongs to school or is admin
      allow get, list: if true; // Simplified for prototype visibility
      allow create: if (isSchoolAdmin(schoolId) || isSuperAdmin());
      allow update: if (isSchoolAdmin(schoolId) || isSuperAdmin());
      allow delete: if (isSchoolAdmin(schoolId) || isSuperAdmin());
    }

    match /schools/{schoolId}/products/{productId} {
      // Products should be readable to show the menu
      allow get, list: if true; 
      allow create, update, delete: if isSchoolAdmin(schoolId) || isSuperAdmin();
    }

    match /schools/{schoolId}/menus/{menuId} {
      // Menus should be readable for parents and POS
      allow get, list: if true;
      allow create, update, delete: if isSchoolAdmin(schoolId) || isSuperAdmin();
    }

    match /schools/{schoolId}/preOrders/{orderId} {
      allow get, list: if true; // Simplified for prototype
      allow create: if true; // In production, check isSignedIn()
      allow update: if isSchoolAdmin(schoolId) || isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    match /schools/{schoolId}/members/{memberId}/wallets/{walletId} {
      allow get, list: if true;
      allow create, update: if true; // In production, strictly controlled
      allow delete: if isSuperAdmin();
    }
  }
}
